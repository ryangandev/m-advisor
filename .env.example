# Your bot's token (Bot tab → Reset Token)
DISCORD_TOKEN=

# Your bot's Application ID (OAuth2 tab → Client ID, or General Information → Application ID)
CLIENT_ID=

# ─────────────────────────────────────────
# RIOT GAMES — https://developer.riotgames.com
# ─────────────────────────────────────────

# Development API key (login → key shown on dashboard, expires every 24h)
RIOT_API_KEY=
